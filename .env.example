# ── 数据库 ──────────────────────────────────────────
DATABASE_URL=postgres://newsquad:newsquad@postgres:5432/newsquad

# ── Redis（可选，不配置则回退到内存模式）─────────────
REDIS_URL=redis://redis:6379

# ── ClickHouse（可选，用于事件日志分析）───────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=squad_events
CLICKHOUSE_USER=squad
CLICKHOUSE_PASSWORD=squad123

# ── 后端服务 ────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8744
# JWT 密钥（生产环境务必修改为随机字符串）
JWT_SECRET=change-me-in-production

# ── Steam API（用于查询玩家信息）─────────────────────
STEAM_API_KEY=

# ── 初始化管理员 ─────────────────────────────────────
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123

# ── CORS ────────────────────────────────────────────
ALLOWED_ORIGIN=*

# ── 日志文件路径（Agent 上报日志时可忽略）────────────
LOG_FILE_PATH=/var/log/game/server.log
